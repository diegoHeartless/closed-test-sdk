<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />

    <application>
        <provider
            android:name="io.closedtest.sdk.internal.discovery.ClosedTestDiscoveryProvider"
            android:authorities="${applicationId}.closedtest.discovery"
            android:exported="true" />

        <!-- Implicit intent for discovery without enumerating all installed apps (ProofFlow queries this action). -->
        <activity
            android:name="io.closedtest.sdk.internal.discovery.ClosedTestDiscoveryStubActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="io.closedtest.sdk.DISCOVERY" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="io.closedtest.sdk.internal.ClosedTestInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>
</manifest>
